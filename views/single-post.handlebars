<div class='single-post-wrap'>
  <a href='/' class='back-link'>← Back to all posts</a>

  <article class='burn-card'>
    <h2 class='card-title'>{{post.title}}</h2>
    <p class='card-meta'>by {{post.user.username}}</p>
    <div class='card-content'>
      <p>{{post.post_text}}</p>
    </div>
    {{#if isOwner}}
      <div class='post-actions'>
        <a href='/dashboard/update/{{post.id}}' class='btn-ghost'>Edit Post</a>
      </div>
    {{/if}}
  </article>

  {{#if post.comments}}
    <div class='comments-section'>
      <h3>Comments</h3>
      {{#each post.comments}}
        <div class='comment-block' data-comment-id='{{id}}'>
          <p>{{comment_text}}</p>
          <div class='comment-footer'>
            <p class='comment-author'>— {{user.username}}</p>
            {{#if isOwner}}
              <button class='delete-comment-btn btn-red' data-id='{{id}}'>Delete</button>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </div>
  {{/if}}

  <div class='comment-form-card'>
    <h3>Add a Comment</h3>
    <form id='new-comment-form'>
      <input type='hidden' name='post-id' value='{{post.id}}' />
      <div class='form-group'>
        <label for='comment-body'>What's the tea?</label>
        <textarea id='comment-body' name='comment-body'></textarea>
      </div>
      <button type='submit' class='btn-pink'>Submit</button>
    </form>
  </div>
</div>

<script src='/js/comment.js'></script>
