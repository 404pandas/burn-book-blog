<div class='auth-page'>
  <div class='burn-form' style='max-width: 660px;'>
    <h2>Edit Post</h2>
    <form id='edit-post-form'>
      <input type='hidden' name='post-id' value='{{post.id}}' />

      <div class='form-group'>
        <label for='post-title'>Title</label>
        <input type='text' id='post-title' name='post-title' value='{{post.title}}' />
      </div>

      <div class='form-group'>
        <label for='post-body'>Content</label>
        <textarea id='post-body' name='post-body'>{{post.post_text}}</textarea>
      </div>

      <div class='form-actions'>
        <div style='display: flex; gap: 10px;'>
          <button type='submit' class='btn-pink'>Update</button>
          <button type='button' id='delete-btn' class='btn-red'>Delete</button>
        </div>
        <a href='/dashboard' class='btn-ghost'>Cancel</a>
      </div>
    </form>
  </div>
</div>

<script src='/js/edit.js'></script>
