<div class='auth-page'>
  <div class='page-header'>
    <h1>Welcome Back</h1>
    <p class='auth-subtitle'>You can't sit with us... unless you log in.</p>
  </div>

  <div class='burn-form'>
    <h2>Login</h2>
    <form id='login-form'>
      <div class='form-group'>
        <label for='username-input-login'>Username</label>
        <input type='text' id='username-input-login' autocomplete='username' />
      </div>
      <div class='form-group'>
        <label for='password-input-login'>Password</label>
        <input type='password' id='password-input-login' autocomplete='current-password' />
      </div>
      <div class='form-actions'>
        <button type='submit' id='login-btn' class='btn-pink'>Login</button>
        <span class='auth-switch'>
          New here? <a href='/signup'>Sign up instead</a>
        </span>
      </div>
    </form>
  </div>
</div>

<script src='/js/login.js'></script>
